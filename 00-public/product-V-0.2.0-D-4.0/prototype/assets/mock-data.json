  "neoDialogues": {
    "lectureIntro": {
      "description": "Neo在学习者首次进入授课模式时自我介绍",
      "turns": [
        {
          "speaker": "Neo",
          "type": "self_intro",
          "text": "你好，我是Neo——你的课程讲师。在接下来的学习中，我会带你一步步理解每个知识点。有任何疑问随时问我，我们开始吧！",
          "delay": 500
