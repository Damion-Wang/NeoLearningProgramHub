      ]
    },
    "pptNarration": {
      "description": "Neo对MANAGER1 Segment 1.1（职场巨婴与保姆经理的困境）的授课讲解",
      "targetSco": "SCO-001-02",
      "turns": [
        {
          "speaker": "Neo",
          "type": "scene_setting",
          "text": "我想先问你一个问题——你有没有觉得，自己每天在公司累死累活，下属却像「职场巨婴」一样，推一下动一下？",
          "delay": 800,
          "emotion": "provocative"
        },
        {
          "speaker": "Neo",
          "type": "core_teaching",
          "text": "如果你有这种感觉，那问题很可能不出在下属身上——而是出在管理方式上。有一个隐喻很贴切：你现在可能是一个「握着方向盘的司机」，什么都自己来，累到不行，同时也剥夺了别人学习驾驶的机会。",
          "delay": 1500,
          "emotion": "insightful"
        },
        {
          "speaker": "Neo",
          "type": "key_point",
          "text": "真正高效的管理者，应该做一个「GPS」——给方向、给指引，但把方向盘交到下属手中。这就是我们这门课要帮你完成的转变：从「指责」到「赋能」。接下来我们先看看，这个转变具体意味着什么。",
          "delay": 1200,
          "emotion": "encouraging"
        }
      ]
    },
    "quizGuidance": {
      "description": "Neo在Quiz环节的引导话术",
      "beforeQuiz": {
        "speaker": "Neo",
        "type": "quiz_intro",
        "text": "学了这些，来测测你的直觉反应。别紧张，这不是考试，而是帮你看清自己目前的管理本能。认真感受一下再选。",
        "delay": 600
      },
      "afterCorrect": {
        "speaker": "Neo",
        "type": "feedback_positive",
        "text": "很好！你已经能识别出「聚焦未来」和「聚焦过去」的区别了。说明前面的内容你理解得很到位。我们继续。",
        "delay": 800
      },
      "afterIncorrect": {
        "speaker": "Neo",
        "type": "feedback_corrective",
        "text": "别灰心，这道题确实有迷惑性。关键在于——虽然提到了「目标」这个词，但问题的核心是在盘点当前的障碍和资源，属于Reality（现状评估）环节。记住：问「在哪里」的是R，问「怎么去」的才是O。",
        "delay": 1200
      }
    },
    "videoGuidance": {
      "description": "Neo在视频前后的引导话术",
      "beforeVideo": {
        "speaker": "Neo",
        "type": "video_intro",
        "text": "接下来是一个案例视频——王经理面对下属会议组织混乱时的两种处理方式。仔细对比他的语气和提问方式，注意看员工的反应有什么不同。",
        "delay": 800
      },
      "afterVideo": {
        "speaker": "Neo",
        "type": "video_debrief",
        "text": "看到了吗？同样是面对同一个问题，王经理只是把「你怎么搞的」换成了「你注意到什么事实」，整个对话的走向就完全不同了。下属从机械点头变成了主动想办法。这就是「提问」的力量——而GROW模型就是帮你把这种提问系统化的工具。",
        "delay": 1500
      }
    }
  },

  "practiceDialogues": {
    "sceneIntro": {
      "title": "GROW辅导对练：会议效率问题",
      "briefing": "你是销售一部经理。你的下属张伟最近负责的周会出勤率持续下降，从85%跌到了60%。张伟主动找到你，表示想改善这个状况，但不知道该怎么做。请运用GROW模型进行辅导对话。",
      "character": {
        "name": "张伟",
        "role": "销售一部主管",
        "personality": "主动型员工，有责任心但缺乏方法",
        "emotionState": "焦虑但积极"
      },
      "evaluationCriteria": [
        "是否按GROW顺序推进对话",
        "Goal阶段是否引导出SMART目标",
        "Reality阶段是否用事实而非主观判断",
        "Options阶段是否持续追问「还有吗」",
        "Will阶段是否锁定具体第一步和时间节点"
      ]
    },
    "actorDialogue": {
      "description": "AI扮演张伟的5轮对话",
      "turns": [
        {
          "round": 1,
          "phase": "开场",
          "actor": {
            "speaker": "张伟",
            "text": "经理，我发现最近周会出勤率一直在掉，从85%跌到60%了。我觉得这样下去不行，但我不太确定问题出在哪里，想跟你聊聊。",
            "emotion": "焦虑",
            "bodyLanguage": "身体前倾，眉头紧锁"
          },
          "expectedPhase": "Goal",
          "coachingHint": "此时应引导张伟明确目标——他希望达到什么出勤率？在什么时间范围内？"
        },
        {
          "round": 2,
          "phase": "目标设定后",
          "actor": {
            "speaker": "张伟",
            "text": "嗯……我希望能在一个月内把出勤率恢复到90%以上吧。毕竟销售信息同步全靠这个周会。",
            "emotion": "思考中",
            "bodyLanguage": "眼神上移回忆，手指轻敲桌面"
          },
          "expectedPhase": "Reality",
          "coachingHint": "目标已初步明确。接下来引导他评估现状——他已经尝试过什么？缺席的人都是谁？原因是什么？"
        },
        {
          "round": 3,
          "phase": "现状盘点后",
          "actor": {
            "speaker": "张伟",
            "text": "我查了一下，主要是外勤人员。他们反映是时间冲突，周一上午他们要跑客户。还有几个人说会议内容跟他们关系不大。其实我之前也试过发邮件提醒，但效果不太好。",
            "emotion": "冷静分析",
            "bodyLanguage": "打开笔记本翻看数据"
          },
          "expectedPhase": "Options",
          "coachingHint": "现状已梳理清晰。进入Options阶段——持续追问「针对这些原因，你觉得可以做什么？还有吗？」"
        },
        {
          "round": 4,
          "phase": "方案发散后",
          "actor": {
            "speaker": "张伟",
            "text": "我想到几个办法：第一，把周会时间从周一上午改到周一下午，避开外勤高峰；第二，设置一个分主题的议程，让每个人都有相关内容；第三……嗯，我想不到了。",
            "emotion": "初步兴奋后犹豫",
            "bodyLanguage": "说到第三点时停顿，看向管理者"
          },
          "expectedPhase": "Options（追问）",
          "coachingHint": "继续追问「还有吗？」——如果他确实想不到了，可以询问许可后补充建议"
        },
        {
          "round": 5,
          "phase": "方案确定后",
          "actor": {
            "speaker": "张伟",
            "text": "对！还可以做一个5分钟的简报摘要发给实在来不了的人，这样至少信息不断档。那我就先从改时间这件事开始做，明天就发通知征集大家对新时间的意见。",
            "emotion": "积极自信",
            "bodyLanguage": "身体挺直，开始在笔记本上记录"
          },
          "expectedPhase": "Will",
          "coachingHint": "很好！确认他的第一步行动和时间节点，并量化把握度——「你有几分把握？」"
        }
      ]
    },
